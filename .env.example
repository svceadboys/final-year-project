# ==============================================================================
# EcoSort AI - Environment Configuration
# ==============================================================================

# ── Database Settings ──
# By default, the application will use SQLite if no DATABASE_URL is provided.
# If you want to use MySQL instead, uncomment and configure the line below:
# DATABASE_URL=mysql+pymysql://admin:password@localhost:3306/smart_waste

# ── Security & Authentication ──
# Secret key used for encoding JWT tokens.
# Change this to a secure random string in production (e.g. run 'openssl rand -hex 32')
SECRET_KEY=yoursecretkey1234567890

# Standard expiration time for admin authentication tokens (in days)
ACCESS_TOKEN_EXPIRE_DAYS=8

# ── Admin User Provisioning ──
# Hardcoded credentials for the single-admin dashboard.
# Passwords should be bcrypt hashed in production scenarios.
ADMIN_EMAIL=admin@ecosort.com
ADMIN_PASSWORD_HASH=$2b$12$EixZaYVK1fsbw1ZfbX3OXePaWxn96p36WQoeG6Lruj3vjIQqiRQYq  # Hash for 'admin123'
